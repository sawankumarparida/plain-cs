@model IEnumerable<cs.Models.Product>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Products</h1>
        <a asp-action="Create" class="btn btn-primary">+ Add Product</a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 border rounded bg-light-subtle">
            <i class="fa-solid fa-box-open fa-3x mb-3 text-muted"></i>
            <h4 class="text-muted">No products found</h4>
            <p>Your database is currently empty. Click the blue button to add your first item!</p>
        </div>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Price</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Price.ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>